prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
sharedlibdir=${libdir}
includedir=${prefix}/include/
zedclibdir=@ZEDC_LIB_PATH@

Name: zlib
Description: zEDC-enabled zlib library with ASCII support for z/OS
Version: 1.2.11

Requires:
Libs: -L${libdir} -L${sharedlibdir} -L${zedclibdir} -lz -lzz
Cflags: -I${includedir}
